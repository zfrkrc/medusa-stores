# ========================================
# Medusa Multi-Storefront - Environment Template
# ========================================

NODE_ENV=production

# Security
# ========================================
JWT_SECRET=your_jwt_secret_here
COOKIE_SECRET=your_cookie_secret_here

# Backend Configuration
# ========================================
# Internal URL for container-to-container communication (Docker network)
# External URL for browser-side requests
MEDUSA_BACKEND_URL=http://hobby-backend:7001
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:7001
NEXT_PUBLIC_DEFAULT_REGION=tr

# Better Auth
# ========================================
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:8001

# Google Auth (OAuth)
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Storefront Publishable Keys
# ========================================
# Get these from your Medusa Admin panel
HOBBY_PUBLISHABLE_KEY=pk_...
CLAY_PUBLISHABLE_KEY=pk_...
SEDEFLI_PUBLISHABLE_KEY=pk_...
